#
# Backend runtime
#
APP_HOST=0.0.0.0
APP_PORT=5001
DEBUG=true

#
# Local LLM server bootstrap
#
AUTO_START_LLM=true
LLM_HOST=127.0.0.1
LLM_PORT=8024

#
# OCR service
# Used by coarse CTD parsing when OCR service is reachable.
#
OCR_SERVICE_URL=http://127.0.0.1:8000
OCR_TIMEOUT_SECONDS=120
OCR_LANG=chi_sim+eng

#
# Storage paths
#
UPLOAD_DIR=agent/agent_backend/data/uploads
PARSE_DIR=agent/agent_backend/data/parsed
SUBMISSION_UPLOAD_DIR=agent/agent_backend/data/submissions/uploads
SUBMISSION_PARSE_DIR=agent/agent_backend/data/submissions/parsed
REPORT_DIR=agent/agent_backend/data/reports
FEEDBACK_ASSET_DIR=agent/agent_backend/data/feedback_assets
VECTOR_SNAPSHOT_DIR=agent/agent_backend/data/vector_snapshots

#
# Database and cache
#
MYSQL_URL=mysql+pymysql://root:1433223aa@127.0.0.1:3306/pre_review_db
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
ES_URL=http://127.0.0.1:9200

#
# Vector store
#
VECTOR_BACKEND=milvus
VECTOR_COLLECTION=agent_collection
MILVUS_URI=http://127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=

#
# Knowledge base indexing
#
KB_CHUNK_MAX_CHARS=1000
KB_CHUNK_OVERLAP=100
KB_SECTION_PATH_SEP= > 
KB_PARSE_WORKERS=2
KB_PROGRESS_MAX_ENTRIES=2000
KB_PROGRESS_TTL_SECONDS=7200

#
# RAG compatibility paths
#
RAG_PROJECT_BASE=
RAG_DEPLOY_BASE=
RAG_BASE=

#
# LLM model routing
#
LLM_CHAT_MODEL=qwen_chat
LLM_PARSE_MODEL=glm_ocr_parse
LLM_EMBEDDING_MODEL=glm_embedding
LLM_RERANK_MODEL=glm_rerank

#
# LLM timeouts and runtime
#
LLM_TIMEOUT_SECONDS=30
LLM_PARSE_TIMEOUT_SECONDS=60
LLM_VERBOSE_LOG=0
LLM_CHAT_CONTEXT_MAX_CHARS=200000
LLM_EMBED_CONTEXT_MAX_CHARS=8000

#
# Provider-specific model parameters
#
LLM_QWEN_LOCAL_CHAT_MODEL=qwen3:32b
LLM_QWEN_LOCAL_CHAT_BASE_URL=http://localhost:8002/v1
LLM_QWEN_LOCAL_CHAT_API_KEY_PATH=temp/key/local_key
LLM_QWEN_LOCAL_CHAT_TIMEOUT_SECONDS=30
LLM_GLM_EMBED_MODEL=embedding-3
LLM_GLM_RERANK_MODEL=rerank
LLM_EMBEDDING_REMOTE_MODEL=text-embedding-v3
LLM_EMBEDDING_DIMENSIONS=
LLM_HASH_EMBED_DIM=128
